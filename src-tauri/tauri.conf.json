{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mkdn",
  "version": "2.2.0",
  "identifier": "io.github.nkarasiak.mkdn",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "TAURI_BUILD=1 npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MKDN",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "A beautiful markdown editor",
    "longDescription": "MKDN is a minimal, browser-based WYSIWYG markdown editor with real-time collaboration, local folder sync, version history, and a plugin system.",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"],
        "section": "editors"
      },
      "appimage": {}
    },
    "windows": {
      "nsis": {
        "displayLanguageSelector": false
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mkdn", "mdx"],
        "mimeType": "text/markdown",
        "description": "Markdown document"
      }
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nkarasiak/mkdn/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNEMEI5MjZBQTdBNkZBREIKUldUYitxYW5hcElMUGFJTnB5VzkvU24wa1hKbVM4bkVWUWNrVHJsZnRjenhUS09hcStHblVUcTYK"
    }
  }
}
