{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "mkdn",
  "version": "2.1.0",
  "identifier": "io.github.mkdn.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "TAURI_BUILD=1 npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "MKDN",
        "width": 1200,
        "height": 800,
        "minWidth": 600,
        "minHeight": 400,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "desktopTemplate": null,
        "files": {}
      },
      "appimage": {}
    },
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mkdn", "mdx"],
        "mimeType": "text/markdown",
        "description": "Markdown document"
      }
    ]
  },
  "plugins": {}
}
